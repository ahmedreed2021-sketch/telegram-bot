MAX_USERS=1000
DATA_DIR=data
SQLITE_PATH=data/bot2.db
# Minimum seconds between handled messages per user (anti-flood)
ANTIFLOOD_SECONDS=0.01

# Max concurrent outbound Telegram API calls when broadcasting
RELAY_CONCURRENCY=20

# SQLite backup interval (seconds); set 0 to disable
BACKUP_INTERVAL_SECONDS=21600
BACKUP_DIR=backups
BACKUP_KEEP=5

# Optional HTTP health check (Railway sets PORT)
# HEALTH_CHECK=true

# --- High traffic / reliability ---
OUTBOX_WORKERS=16
OUTBOUND_GLOBAL_SEND_LIMIT=120
AIOHTTP_CONNECTOR_LIMIT=256
UPDATE_TASKS_CONCURRENCY=1000

START_BUCKET_CAPACITY=1000
START_BUCKET_REFILL_PER_SEC=1000
START_CONCURRENCY=300
START_PER_USER_DEBOUNCE_SEC=5

GLOBAL_MSG_BUCKET_CAPACITY=5000
GLOBAL_MSG_BUCKET_REFILL_PER_SEC=5000
SLIDING_WINDOW_SEC=2
SLIDING_WINDOW_MAX_MSGS=1000
RATE_LIMITER_MAX_TRACKED_USERS=50000

CLEANUP_INTERVAL_SEC=600
OUTBOX_DONE_RETENTION_SEC=604800

# One-shot: copy this .db file over SQLITE_PATH before bot opens DB (then unset)
# RESTORE_DB_FROM=/path/to/backup.db

LOG_LEVEL=INFO
